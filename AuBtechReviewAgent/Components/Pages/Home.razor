@page "/"
@rendermode InteractiveServer

@using System.IO
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject AuBtechReviewAgent.PrismaReviewEngine ReviewEngine
@inject ProtectedSessionStorage SessionStorage
@inject IJSRuntime JS

<header class="bg-[#003B5C] text-white flex-none shrink-0 z-50 shadow-md">
    <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center space-x-3">
            <span class="font-bold tracking-tight text-sm">AARHUS UNIVERSITY</span>
            <span class="text-white/40 font-light">|</span>
            <span class="text-xs tracking-wider font-medium opacity-90 uppercase">au-btech-literature-review-agent</span>
        </div>
        <nav class="flex items-center space-x-6 text-xs font-semibold uppercase tracking-wider">
            <a href="/" class="text-white border-b-2 border-white py-4">Dashboard</a>
            <a href="/spec-matrix" class="text-white/70 hover:text-white transition-colors py-4">Review Output</a>
        </nav>
    </div>
</header>

<div class="flex-1 flex flex-col min-h-0 overflow-hidden items-center justify-center max-w-7xl w-full mx-auto p-4 lg:p-6 space-y-4">
    
    <div class="w-full text-center flex-none shrink-0 space-y-1">
        <h1 class="text-2xl lg:text-3xl font-light text-gray-900 tracking-tight">Literature Review Agent</h1>
        <p class="text-xs font-mono tracking-widest text-[#003B5C] uppercase font-bold">Traceable PRISMA Reviews</p>
    </div>

    <div class="w-full flex-1 grid grid-cols-1 lg:grid-cols-12 gap-4 min-h-0 overflow-hidden">
        
        <div class="lg:col-span-5 flex flex-col space-y-4 min-h-0">
            <div class="bg-white border border-gray-200 rounded-lg p-4 flex flex-col justify-between shadow-sm flex-1 min-h-0">
                <div class="flex justify-between items-center mb-2 flex-none">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 block">Execution Configuration</span>
                    <button @onclick="OpenKeyModal" class="text-[10px] bg-gray-100 hover:bg-gray-200 border border-gray-300 text-gray-700 px-2 py-0.5 rounded transition-all flex items-center gap-1">
                        <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                        <span>API Credentials</span>
                    </button>
                </div>

                <div class="mb-3 flex-none">
                    @if (isUsingByok)
                    {
                        <div class="bg-green-50 border border-green-200 rounded p-2 text-[11px] text-green-800 flex items-center justify-between font-sans">
                            <span class="font-medium flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                                Active Mode: Bring Your Own Key Tier
                            </span>
                            <span class="font-mono text-[10px] bg-green-100 text-green-800 px-1 rounded">3 req / min</span>
                        </div>
                    }
                    else
                    {
                        <div class="bg-amber-50 border border-amber-200 rounded p-2 text-[11px] text-amber-800 flex items-center justify-between font-sans">
                            <span class="font-medium flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                                Active Mode: Shared Server Default Tier
                            </span>
                            <span class="font-mono text-[10px] bg-amber-100 text-amber-800 px-1 rounded">1 req / day</span>
                        </div>
                    }
                </div>
                
                <div class="space-y-3 overflow-y-auto pr-1 flex-1 text-left">
                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Search Query</label>
                        <input type="text" @bind="searchQuery" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all" />
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Review Objective</label>
                        <textarea @bind="reviewObjective" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all"></textarea>
                    </div>

                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Date From</label>
                            <input type="date" @bind="dateFrom" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all" />
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Date To</label>
                            <input type="date" @bind="dateTo" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Inclusion Criteria</label>
                        <textarea @bind="inclusionCriteria" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all"></textarea>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Exclusion Criteria</label>
                        <textarea @bind="exclusionCriteria" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all"></textarea>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Artifact Target</label>
                        <select @onchange="HandlePresetArtifactSelection" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all mb-1.5 font-sans">
                            <option value="Custom">Custom Target Directive...</option>
                            <option value="LoopModel" selected>Conceptual Architectural Loop Diagram (Mermaid / TikZ)</option>
                            <option value="Patterns">Bullet-Point System Safety Design Patterns Spec</option>
                            <option value="Matrix">Comparative Multi-Agent Architectural Trade-off Matrix</option>
                        </select>
                        <textarea @bind="synthesisTargetDirective" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all font-mono" placeholder="Provide instructions on what the engine should create in section 4 based on the retrieved data facts..."></textarea>
                    </div>

                    <div class="pt-1 grid grid-cols-2 gap-2 items-center">
                        <label class="relative flex items-center cursor-pointer select-none text-xs text-gray-700 font-semibold gap-2">
                            <input type="checkbox" @bind="requirePeerReview" class="w-4 h-4 text-[#003B5C] bg-gray-50 border-gray-300 rounded focus:ring-[#003B5C] focus:ring-2 transition-all accent-[#003B5C]" />
                            <span>Peer-Reviewed Only</span>
                        </label>
                        
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-gray-500 mb-0.5">Max Results of Each Source</label>
                            <input type="number" min="1" max="50" @bind="maxResults" class="w-full p-1 bg-gray-50 border border-gray-300 rounded text-xs text-center font-mono focus:outline-none focus:border-[#003B5C]" />
                        </div>
                    </div>
                </div>

                <div class="pt-3 flex-none">
                    <button @onclick="StartReviewProcess" disabled="@isSearching" class="w-full py-2.5 px-4 text-white text-xs font-bold uppercase tracking-wider rounded transition-all hover:bg-opacity-95 disabled:opacity-50 shadow-sm" style="background-color: #003B5C;">
                        @if (isSearching)
                        {
                            <span class="flex items-center justify-center gap-2">
                                <span class="animate-spin inline-block w-3.5 h-3.5 border-2 border-white border-t-transparent rounded-full"></span>
                                <span>PARSING ENGINE...</span>
                            </span>
                        }
                        else
                        {
                            <span>Execute Search</span>
                        }
                    </button>
                </div>
            </div>

            <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm flex-none">
                <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 block mb-3">PRISMA Funnel Tracking Fields</span>
                <div class="grid grid-cols-2 gap-3">
                    <div class="p-3 bg-gray-50 border border-gray-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-gray-400 uppercase tracking-wider">Identified</span>
                        <span class="text-xl font-bold text-[#003B5C] font-mono">@totalIdentified</span>
                    </div>
                    <div class="p-3 bg-gray-50 border border-gray-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-gray-400 uppercase tracking-wider">Screened</span>
                        <span class="text-xl font-bold text-gray-700 font-mono">@screenedCount</span>
                    </div>
                    <div class="p-3 bg-red-50/60 border border-red-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-red-500 uppercase tracking-wider">Excluded</span>
                        <span class="text-xl font-bold text-red-600 font-mono">@excludedCount</span>
                    </div>
                    <div class="p-3 bg-green-50/60 border border-green-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-green-600 uppercase tracking-wider">Included</span>
                        <span class="text-xl font-bold text-green-700 font-mono">@includedCount</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 flex flex-col min-h-0 border border-gray-200 rounded-lg bg-white shadow-sm overflow-hidden">
            <div class="bg-gray-800 text-white px-4 py-2.5 text-xs font-mono flex justify-between items-center flex-none">
                <span>JSON output</span>
                <span class="text-[9px] opacity-50 uppercase tracking-widest font-bold">Mistral LLM</span>
            </div>
            <div class="flex-1 bg-gray-950 p-4 font-mono text-xs text-green-400 overflow-y-auto whitespace-pre-wrap leading-relaxed">
                @rawJsonLogs
            </div>
        </div>

    </div>
</div>

@if (showKeyModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-xs flex items-center justify-center z-[100] p-4 font-sans animate-fadeIn">
        <div class="bg-white border border-gray-200 w-full max-w-md rounded-lg shadow-2xl overflow-hidden flex flex-col text-left">
            <div class="bg-[#003B5C] text-white p-4 flex justify-between items-center">
                <div>
                    <h3 class="text-sm font-bold tracking-tight uppercase">Credential Vault Config</h3>
                    <p class="text-[10px] opacity-70 font-mono mt-0.5">Isolate Custom Session Keys via SignalR Enclave</p>
                </div>
                <button @onclick="CloseKeyModal" class="text-white/60 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="p-4 space-y-3 overflow-y-auto text-xs text-gray-700">
                <div class="bg-blue-50 border border-blue-100 text-blue-800 p-2.5 rounded text-[11px] leading-normal font-light">
                    <strong>Browser Encryption Notice:</strong> Keys entered here are encrypted and stored purely inside your browser's local tab session. They never touch public logs, are never saved on server disks, and vanish completely when the tab is closed.
                </div>
                <div>
                    <label class="block font-bold text-gray-600 mb-1 uppercase text-[10px]">Mistral AI Large API Key</label>
                    <input type="password" placeholder="Defaults to server standard key if blank..." @bind="modalMistral" class="w-full p-2 border border-gray-300 rounded font-mono focus:outline-none focus:border-[#003B5C]" />
                </div>
                <div>
                    <label class="block font-bold text-gray-600 mb-1 uppercase text-[10px]">Elsevier / Scopus Scopus Key</label>
                    <input type="password" placeholder="Defaults to server standard key if blank..." @bind="modalElsevier" class="w-full p-2 border border-gray-300 rounded font-mono focus:outline-none focus:border-[#003B5C]" />
                </div>
                <div>
                    <label class="block font-bold text-gray-600 mb-1 uppercase text-[10px]">IEEE Xplore Gateway Key</label>
                    <input type="password" placeholder="Optional..." @bind="modalIeee" class="w-full p-2 border border-gray-300 rounded font-mono focus:outline-none focus:border-[#003B5C]" />
                </div>
                <div>
                    <label class="block font-bold text-gray-600 mb-1 uppercase text-[10px]">SerpApi Key (Google Scholar / ResearchGate)</label>
                    <input type="password" placeholder="Optional..." @bind="modalScholar" class="w-full p-2 border border-gray-300 rounded font-mono focus:outline-none focus:border-[#003B5C]" />
                </div>
            </div>
            <div class="bg-gray-50 px-4 py-3 border-t border-gray-200 flex justify-end gap-2">
                <button @onclick="ClearVault" class="px-3 py-1.5 text-xs text-red-600 hover:text-red-800 transition-colors uppercase font-semibold">Clear Session</button>
                <button @onclick="SaveSessionKeys" class="px-4 py-1.5 text-xs text-white font-bold bg-[#003B5C] rounded shadow hover:bg-opacity-95 uppercase tracking-wide transition-all">Apply to Session</button>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private UiStateContainer State { get; set; } = default!;

    private string searchQuery { get => State.SearchQuery; set => State.SearchQuery = value; }
    private string reviewObjective { get => State.ReviewObjective; set => State.ReviewObjective = value; }
    private string inclusionCriteria { get => State.InclusionCriteria; set => State.InclusionCriteria = value; }
    private string exclusionCriteria { get => State.ExclusionCriteria; set => State.ExclusionCriteria = value; }
    private DateTime dateFrom { get => State.DateFrom; set => State.DateFrom = value; }
    private DateTime dateTo { get => State.DateTo; set => State.DateTo = value; }
    private bool requirePeerReview { get => State.RequirePeerReview; set => State.RequirePeerReview = value; }
    private string synthesisTargetDirective { get => State.SynthesisTargetDirective; set => State.SynthesisTargetDirective = value; }

    private string rawJsonLogs { get => State.RawJsonLogs; set => State.RawJsonLogs = value; }
    private int totalIdentified { get => State.TotalIdentified; set => State.TotalIdentified = value; }
    private int screenedCount { get => State.ScreenedCount; set => State.ScreenedCount = value; }
    private int excludedCount { get => State.ExcludedCount; set => State.ExcludedCount = value; }
    private int includedCount { get => State.IncludedCount; set => State.IncludedCount = value; }
    private bool isSearching { get => State.IsSearching; set => State.IsSearching = value; }

    private int maxResults { get; set; } = 5;

    private bool showKeyModal = false;
    private bool isUsingByok = false;
    private AuBtechReviewAgent.UserApiKeys? sessionKeys = null;

    private string modalMistral = "";
    private string modalElsevier = "";
    private string modalIeee = "";
    private string modalScholar = "";

    // FIXED: Added a session fallback property accessor to the scoped container state
    private Guid currentSessionId 
    { 
        get => State.CurrentSessionId == Guid.Empty ? (State.CurrentSessionId = Guid.NewGuid()) : State.CurrentSessionId;
        set => State.CurrentSessionId = value; 
    }

    protected override async Task OnInitializedAsync()
    {
        if (isSearching)
        {
            ReviewEngine.OnProgressUpdated += HandleEngineProgress;
            StartLogMonitoringLoop(); // Resume background log updates if navigating back mid-run
        }
        else 
        {
            // Rehydrate past search session text logs if navigating back to home after run completion
            string dynamicStatePath = Path.Combine(Directory.GetCurrentDirectory(), "WorkspaceStore", currentSessionId.ToString("N"), "transparent-process.json");
            if (File.Exists(dynamicStatePath))
            {
                try
                {
                    using var fileStream = new FileStream(dynamicStatePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
                    using var reader = new StreamReader(fileStream);
                    rawJsonLogs = await reader.ReadToEndAsync();
                }
                catch { }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var result = await SessionStorage.GetAsync<string>("encrypted_byok_payload");
                if (result.Success && !string.IsNullOrWhiteSpace(result.Value))
                {
                    sessionKeys = JsonSerializer.Deserialize<AuBtechReviewAgent.UserApiKeys>(result.Value);
                    isUsingByok = sessionKeys != null && (!string.IsNullOrWhiteSpace(sessionKeys.MistralApiKey) || !string.IsNullOrWhiteSpace(sessionKeys.ElsevierApiKey));
                    
                    if (sessionKeys != null)
                    {
                        modalMistral = sessionKeys.MistralApiKey ?? "";
                        modalElsevier = sessionKeys.ElsevierApiKey ?? "";
                        modalIeee = sessionKeys.IeeeApiKey ?? "";
                        modalScholar = sessionKeys.ScholarApiKey ?? "";
                    }
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }

    private void OpenKeyModal() => showKeyModal = true;
    private void CloseKeyModal() => showKeyModal = false;

    private async Task SaveSessionKeys()
    {
        string sMistral = AuBtechReviewAgent.SecurityUtility.SanitizeInput(modalMistral);
        string sElsevier = AuBtechReviewAgent.SecurityUtility.SanitizeInput(modalElsevier);
        string sIeee = AuBtechReviewAgent.SecurityUtility.SanitizeInput(modalIeee);
        string sScholar = AuBtechReviewAgent.SecurityUtility.SanitizeInput(modalScholar);

        sessionKeys = new AuBtechReviewAgent.UserApiKeys(sMistral, sElsevier, sIeee, sScholar);
        isUsingByok = !string.IsNullOrWhiteSpace(sMistral) || !string.IsNullOrWhiteSpace(sElsevier);

        string jsonPayload = JsonSerializer.Serialize(sessionKeys);
        await SessionStorage.SetAsync("encrypted_byok_payload", jsonPayload);
        
        showKeyModal = false;
        StateHasChanged();
    }

    private async Task ClearVault()
    {
        modalMistral = modalElsevier = modalIeee = modalScholar = "";
        sessionKeys = null;
        isUsingByok = false;
        await SessionStorage.DeleteAsync("encrypted_byok_payload");
        showKeyModal = false;
        StateHasChanged();
    }

    private void HandlePresetArtifactSelection(ChangeEventArgs e)
    {
        string chosen = e.Value?.ToString() ?? "Custom";
        synthesisTargetDirective = chosen switch
        {
            "LoopModel" => "Conceptual Architectural Loop Diagram detailing fault-tolerance gating mechanisms.",
            "Patterns" => "Create a complete numbered layout list of software design patterns for runtime safeguards and error containment.",
            "Matrix" => "Create a detailed text table matrix comparing the specific tool-use security trade-offs of the reviewed engines.",
            _ => synthesisTargetDirective
        };
    }

    private async Task StartReviewProcess()
    {
        string cleanQuery = AuBtechReviewAgent.SecurityUtility.SanitizeInput(searchQuery);
        string cleanObjective = AuBtechReviewAgent.SecurityUtility.SanitizeInput(reviewObjective);
        string cleanInclusion = AuBtechReviewAgent.SecurityUtility.SanitizeInput(inclusionCriteria);
        string cleanExclusion = AuBtechReviewAgent.SecurityUtility.SanitizeInput(exclusionCriteria);
        string cleanDirective = AuBtechReviewAgent.SecurityUtility.SanitizeInput(synthesisTargetDirective);

        totalIdentified = 0;
        screenedCount = 0;
        excludedCount = 0;
        includedCount = 0;
        State.PassedPeerReviewCount = 0;
        State.FailedPeerReviewCount = 0;
        isSearching = true;
        rawJsonLogs = "{\n  \"status\": \"Initializing secure user session isolation container...\"\n}";
        
        // Refresh session key token on fresh user click loops
        currentSessionId = Guid.NewGuid();

        ReviewEngine.OnProgressUpdated += HandleEngineProgress;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                await ReviewEngine.RunReviewLoopAsync(
                    currentSessionId, 
                    cleanQuery, 
                    cleanObjective, 
                    cleanInclusion, 
                    cleanExclusion, 
                    maxResults, 
                    requirePeerReview, 
                    cleanDirective,
                    sessionKeys
                );
            }
            catch (Exception ex)
            {
                rawJsonLogs = $"{{\n  \"error\": \"{ex.Message}\"\n}}";
            }
            finally
            {
                ReviewEngine.OnProgressUpdated -= HandleEngineProgress;
                isSearching = false;
                await InvokeAsync(StateHasChanged);
            }
        });

        StartLogMonitoringLoop();
    }

private void StartLogMonitoringLoop()
    {
        // FIXED: Explicitly look inside the sandboxed workspace folder instead of checking the application root
        string dynamicStatePath = Path.Combine(Directory.GetCurrentDirectory(), "WorkspaceStore", currentSessionId.ToString("N"), "transparent-process.json");

        _ = Task.Run(async () =>
        {
            while (isSearching)
            {
                await Task.Delay(250); 
                if (File.Exists(dynamicStatePath))
                {
                    try
                    {
                        using var fileStream = new FileStream(dynamicStatePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
                        using var reader = new StreamReader(fileStream);
                        string updatedContent = await reader.ReadToEndAsync();

                        await InvokeAsync(() =>
                        {
                            rawJsonLogs = updatedContent;
                            StateHasChanged();
                        });
                    }
                    catch { }
                }
            }
        });
    }

    private void HandleEngineProgress(ReviewStats updatedStats)
    {
        InvokeAsync(() =>
        {
            totalIdentified = updatedStats.TotalIdentified;
            screenedCount = updatedStats.Screened;
            excludedCount = updatedStats.Excluded;
            includedCount = updatedStats.Included;
            
            State.PassedPeerReviewCount = updatedStats.PassedPeerReviewCheck;
            State.FailedPeerReviewCount = updatedStats.FailedPeerReviewCheck;
            
            if (updatedStats.ProcessingStage == "Complete")
            {
                isSearching = false;
            }
            
            StateHasChanged();
        });
    }
}