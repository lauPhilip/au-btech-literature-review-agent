@page "/"
@rendermode InteractiveServer

@using System.IO
@using System.Text.Json
@inject AuBtechReviewAgent.PrismaReviewEngine ReviewEngine
@inject IJSRuntime JS

<header class="bg-[#003B5C] text-white flex-none shrink-0 z-50 shadow-md">
    <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center space-x-3">
            <span class="font-bold tracking-tight text-sm">AARHUS UNIVERSITY</span>
            <span class="text-white/40 font-light">|</span>
            <span class="text-xs tracking-wider font-medium opacity-90 uppercase">au-btech-literature-review-agent</span>
        </div>
        <nav class="flex items-center space-x-6 text-xs font-semibold uppercase tracking-wider">
            <a href="/" class="text-white border-b-2 border-white py-4">Dashboard</a>
            <a href="/spec-matrix" class="text-white/70 hover:text-white transition-colors py-4">Review Output</a>
        </nav>
    </div>
</header>

<div class="flex-1 flex flex-col min-h-0 overflow-hidden items-center justify-center max-w-7xl w-full mx-auto p-4 lg:p-6 space-y-4">
    
    <div class="w-full text-center flex-none shrink-0 space-y-1">
        <h1 class="text-2xl lg:text-3xl font-light text-gray-900 tracking-tight">Literature Review Agent</h1>
        <p class="text-xs font-mono tracking-widest text-[#003B5C] uppercase font-bold">Traceable PRISMA Reviews</p>
    </div>

    <div class="w-full flex-1 grid grid-cols-1 lg:grid-cols-12 gap-4 min-h-0 overflow-hidden">
        
        <div class="lg:col-span-5 flex flex-col space-y-4 min-h-0">
            <div class="bg-white border border-gray-200 rounded-lg p-4 flex flex-col justify-between shadow-sm flex-1 min-h-0">
                <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 block mb-2">Execution Configuration</span>
                
                <div class="space-y-3 overflow-y-auto pr-1 flex-1 text-left">
                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Search Query</label>
                        <input type="text" @bind="searchQuery" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all" />
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Review Objective</label>
                        <textarea @bind="reviewObjective" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all"></textarea>
                    </div>

                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Date From</label>
                            <input type="date" @bind="dateFrom" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all" />
                        </div>
                        <div>
                            <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Date To</label>
                            <input type="date" @bind="dateTo" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner transition-all" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Inclusion Criteria</label>
                        <textarea @bind="inclusionCriteria" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all"></textarea>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold uppercase text-gray-600 mb-1">Exclusion Criteria</label>
                        <textarea @bind="exclusionCriteria" rows="2" class="w-full p-2 bg-gray-50 border border-gray-300 rounded focus:outline-none focus:border-[#003B5C] text-xs shadow-inner resize-none transition-all"></textarea>
                    </div>

                    <div class="pt-1 grid grid-cols-2 gap-2 items-center">
                        <label class="relative flex items-center cursor-pointer select-none text-xs text-gray-700 font-semibold gap-2">
                            <input type="checkbox" @bind="requirePeerReview" class="w-4 h-4 text-[#003B5C] bg-gray-50 border-gray-300 rounded focus:ring-[#003B5C] focus:ring-2 transition-all accent-[#003B5C]" />
                            <span>Peer-Reviewed Only</span>
                        </label>
                        
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-gray-500 mb-0.5">Max Results of Each Source</label>
                            <input type="number" min="1" max="50" @bind="maxResults" class="w-full p-1 bg-gray-50 border border-gray-300 rounded text-xs text-center font-mono focus:outline-none focus:border-[#003B5C]" />
                        </div>
                    </div>
                </div>

                <div class="pt-3 flex-none">
                    <button @onclick="StartReviewProcess" disabled="@isSearching" class="w-full py-2.5 px-4 text-white text-xs font-bold uppercase tracking-wider rounded transition-all hover:bg-opacity-95 disabled:opacity-50 shadow-sm" style="background-color: #003B5C;">
                        @if (isSearching)
                        {
                            <span class="flex items-center justify-center gap-2">
                                <span class="animate-spin inline-block w-3.5 h-3.5 border-2 border-white border-t-transparent rounded-full"></span>
                                <span>PARSING ENGINE...</span>
                            </span >
                        }
                        else
                        {
                            <span>Execute Search</span>
                        }
                    </button>
                </div>
            </div>

            <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm flex-none">
                <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 block mb-3">PRISMA Funnel Tracking Fields</span>
                <div class="grid grid-cols-2 gap-3">
                    <div class="p-3 bg-gray-50 border border-gray-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-gray-400 uppercase tracking-wider">Identified</span>
                        <span class="text-xl font-bold text-[#003B5C] font-mono">@totalIdentified</span>
                    </div>
                    <div class="p-3 bg-gray-50 border border-gray-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-gray-400 uppercase tracking-wider">Screened</span>
                        <span class="text-xl font-bold text-gray-700 font-mono">@screenedCount</span>
                    </div>
                    <div class="p-3 bg-red-50/60 border border-red-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-red-500 uppercase tracking-wider">Excluded</span>
                        <span class="text-xl font-bold text-red-600 font-mono">@excludedCount</span>
                    </div>
                    <div class="p-3 bg-green-50/60 border border-green-100 rounded text-left">
                        <span class="block text-[9px] font-bold text-green-600 uppercase tracking-wider">Included</span>
                        <span class="text-xl font-bold text-green-700 font-mono">@includedCount</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 flex flex-col min-h-0 border border-gray-200 rounded-lg bg-white shadow-sm overflow-hidden">
            <div class="bg-gray-800 text-white px-4 py-2.5 text-xs font-mono flex justify-between items-center flex-none">
                <span>JSON output</span>
                <span class="text-[9px] opacity-50 uppercase tracking-widest font-bold">Mistral LLM</span>
            </div>
            <div class="flex-1 bg-gray-950 p-4 font-mono text-xs text-green-400 overflow-y-auto whitespace-pre-wrap leading-relaxed">
@rawJsonLogs
            </div>
        </div>

    </div>
</div>

@code {
    [Inject] private UiStateContainer State { get; set; } = default!;

    private string searchQuery { get => State.SearchQuery; set => State.SearchQuery = value; }
    private string reviewObjective { get => State.ReviewObjective; set => State.ReviewObjective = value; }
    private string inclusionCriteria { get => State.InclusionCriteria; set => State.InclusionCriteria = value; }
    private string exclusionCriteria { get => State.ExclusionCriteria; set => State.ExclusionCriteria = value; }
    private DateTime dateFrom { get => State.DateFrom; set => State.DateFrom = value; }
    private DateTime dateTo { get => State.DateTo; set => State.DateTo = value; }
    private bool requirePeerReview { get => State.RequirePeerReview; set => State.RequirePeerReview = value; }

    private string rawJsonLogs { get => State.RawJsonLogs; set => State.RawJsonLogs = value; }
    private int totalIdentified { get => State.TotalIdentified; set => State.TotalIdentified = value; }
    private int screenedCount { get => State.ScreenedCount; set => State.ScreenedCount = value; }
    private int excludedCount { get => State.ExcludedCount; set => State.ExcludedCount = value; }
    private int includedCount { get => State.IncludedCount; set => State.IncludedCount = value; }
    private bool isSearching { get => State.IsSearching; set => State.IsSearching = value; }

    // Backup local variable defaulting to 5 if state container doesn't expose it yet
    private int maxResults { get; set; } = 5;

    protected override void OnInitialized()
    {
        if (isSearching)
        {
            ReviewEngine.OnProgressUpdated += HandleEngineProgress;
        }
    }

    private async Task StartReviewProcess()
    {
        if (File.Exists("prisma-report.json"))
        {
            try { File.Delete("prisma-report.json"); } catch { }
        }

        string papersDir = Path.Combine(Directory.GetCurrentDirectory(), "PapersWorkspace");
        if (Directory.Exists(papersDir))
        {
            try
            {
                foreach (string file in Directory.GetFiles(papersDir))
                {
                    File.Delete(file);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Workspace folder purge warning: {ex.Message}");
            }
        }

        totalIdentified = 0;
        screenedCount = 0;
        excludedCount = 0;
        includedCount = 0;
        isSearching = true;
        rawJsonLogs = "{\n  \"status\": \"Initializing TraceableAI framework and purging workspace folders...\"\n}";
        
        ReviewEngine.OnProgressUpdated += HandleEngineProgress;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                // ─── FORWARD MAX RESULTS SELECTION INTO PIPELINE LOOP ─────────────
                await ReviewEngine.RunReviewLoopAsync(searchQuery, reviewObjective, inclusionCriteria, exclusionCriteria, maxResults);
            }
            catch (Exception ex)
            {
                rawJsonLogs = $"{{\n  \"error\": \"{ex.Message}\"\n}}";
            }
            finally
            {
                ReviewEngine.OnProgressUpdated -= HandleEngineProgress;
                isSearching = false;
                await InvokeAsync(StateHasChanged);
            }
        });

        _ = Task.Run(async () =>
        {
            while (isSearching)
            {
                await Task.Delay(200); 
                if (File.Exists("transparent-process.json"))
                {
                    try
                    {
                        using var fileStream = new FileStream("transparent-process.json", FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
                        using var reader = new StreamReader(fileStream);
                        string updatedContent = await reader.ReadToEndAsync();

                        await InvokeAsync(() =>
                        {
                            rawJsonLogs = updatedContent;
                            StateHasChanged();
                        });
                    }
                    catch { }
                }
            }
        });
    }

    private void HandleEngineProgress(ReviewStats updatedStats)
    {
        InvokeAsync(() =>
        {
            totalIdentified = updatedStats.TotalIdentified;
            screenedCount = updatedStats.Screened;
            excludedCount = updatedStats.Excluded;
            includedCount = updatedStats.Included;
            
            if (updatedStats.ProcessingStage == "Complete")
            {
                isSearching = false;
            }
            
            StateHasChanged();
        });
    }
}